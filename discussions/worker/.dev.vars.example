# Copy to `.dev.vars` for local development (`.dev.vars` is gitignored). These override
# wrangler.toml [vars] under `wrangler dev`. In production the same names are set as
# secrets with `wrangler secret put NAME` (deploy.sh handles this).

# Signs the session cookie. Any long random string for local; a real secret in prod.
SESSION_SECRET=dev-local-session-secret-change-me

# GitHub OAuth App credentials. Leave blank to develop without sign-in (read-only);
# fill them (and create a local OAuth App with callback http://localhost:8787/auth/callback)
# to test the full sign-in flow locally.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# localhost:4321 (blog) and localhost:8787 (this Worker) are same-site, so a plain
# SameSite=Lax cookie is sent; keep this 0 locally. Prod uses 1 (SameSite=None; Secure).
COOKIE_CROSS_SITE=0

# The Worker's own base URL, used as the OAuth redirect base. Match your dev port.
PUBLIC_BASE_URL=http://localhost:8787
