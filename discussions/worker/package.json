{
  "name": "discussions-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted blog comments on Hono + Cloudflare D1 (a port of discussions/backend).",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "migrate:local": "wrangler d1 migrations apply discussions --local",
    "migrate:remote": "wrangler d1 migrations apply discussions --remote",
    "seed:local": "wrangler d1 execute discussions --local --file=./seed.sql"
  },
  "dependencies": {
    "@shikijs/rehype": "^1.24.0",
    "hono": "^4.6.14",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "shiki": "^1.24.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "typescript": "^5.7.2",
    "wrangler": "^4.110.0"
  }
}
