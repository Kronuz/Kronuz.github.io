---
/**
 * Reusable Astro wrapper for the framework-independent Discussions widget.
 *
 * `backend` is the complete tenant base URL. PUBLIC_DISCUSSIONS_BACKEND and
 * PUBLIC_DISCUSSIONS_ACCESS_KEY provide convenient build-time defaults.
 */
import '../widget/discussions.css';
import '../widget/highlight.css';

interface Props {
  /** Stable per-page key, usually the post slug. */
  term?: string;
  /** Page title stored with the discussion. */
  title?: string;
  /** Page subtitle stored with the discussion. */
  subtitle?: string;
  /** Canonical page URL stored with the discussion. */
  url?: string;
  /** Complete tenant base URL. */
  backend?: string;
  /** Static tenant capability. Empty means public. */
  accessKey?: string;
  /** Cosmetic suffix removed from displayed account names. */
  stripSuffix?: string;
  /** Public GIPHY browser API key. Empty disables the GIF picker. */
  giphyKey?: string;
  /** Force a color theme. Omit to follow the site. */
  theme?: 'light' | 'dark';
}

const {
  term,
  title,
  subtitle,
  url,
  backend = import.meta.env.PUBLIC_DISCUSSIONS_BACKEND ?? '',
  accessKey = import.meta.env.PUBLIC_DISCUSSIONS_ACCESS_KEY ?? '',
  stripSuffix = '',
  giphyKey = '',
  theme,
} = Astro.props;
---

<section class="gc not-content" data-term={term} data-title={title} data-subtitle={subtitle} data-url={url} data-backend={backend} data-access-key={accessKey} data-strip-suffix={stripSuffix} data-giphy-key={giphyKey} data-theme={theme}></section>

<script>
  import '../widget/discussions.js';
</script>
