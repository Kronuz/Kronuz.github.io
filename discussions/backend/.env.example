# Reference + first-install defaults for the discussions backend.
#
# You normally don't write .env by hand: run ./install.sh and it prompts for each
# value (defaulting to the uncommented values here when there's no .env yet),
# writes .env, and derives ../../site.config.json from it. This file documents
# every key and is the source of those first-install defaults. NEVER commit .env.

# --- OAuth (sign-in) ---------------------------------------------------------
# From your GitHub OAuth App (https://github.com/settings/developers). OAuth is used
# only to learn who the reader is (login/name/avatar); the comment data lives locally.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Which backend holds the discussions. "sqlite" (default) = self-hosted system of record
# in discussions.db; OAuth only identifies the reader. "github" = real GitHub Discussions
# via GraphQL: the reader's own token writes (authentic authorship, like giscus), a server
# token reads for signed-out visitors. Use github for a repo you own (an org that
# restricts OAuth Apps blocks reader-token writes, so such a deployment uses sqlite).
DISCUSSIONS_BACKEND=sqlite
# Server-side token the github backend uses to READ discussions for signed-out visitors
# (GitHub's GraphQL needs auth even for public data; writes always use the reader's own
# token). A fine-grained PAT with Discussions:read (or classic public_repo read) on REPO.
# Unused by the sqlite backend.
# GITHUB_READ_TOKEN=
# Extra GitHub logins allowed to moderate (hide/delete any comment), comma-separated.
# This is the only way to grant admin: there is no server token.
ADMIN_LOGINS=
# Scope requested at sign-in. Defaults (config.py) to "read:user" for the sqlite backend
# (identity only) and "repo" for the github backend (so the reader's token can write
# Discussions). Uncomment to override.
# OAUTH_SCOPE=read:user

# --- App ---------------------------------------------------------------------
# owner/name of the repo. Shown by /api/health and used as the Discussions repo for the
# github backend. The sqlite backend renders Markdown locally (cmark-gfm), so it needs no
# token. Blank = install.sh guesses it from `gh repo view`.
REPO=
# Discussion category new threads are created under (github mode only; matched by name
# or slug, case-insensitive). Blank = General. Unused by the sqlite backend.
DISCUSSION_CATEGORY=General
# Canonical site/blog URL; also used as the allowed CORS origin.
SITE_URL=
ALLOWED_ORIGINS=
# This backend's externally reachable base URL (used to build the OAuth callback).
# Blank = install.sh uses https://<this-host-fqdn>:<PORT>.
PUBLIC_BASE_URL=
# Set 1 when the page and backend are on different origins (production: needs
# HTTPS on both). Use 0 only for a same-origin local /demo.
COOKIE_CROSS_SITE=1
# Fixed so sessions survive a restart (install.sh generates one if unset).
# SESSION_SECRET=

# --- Build-only (the backend ignores these; site.config.json is built from them)
SITE_TITLE="My Blog"
SITE_DESCRIPTION="A blog built with Astro + Starlight."
# Repo web URL. Blank = https://github.com/<REPO>.
REPO_URL=
# Display-only: drop this suffix from commenter logins when shown (e.g. an EMU org
# suffix like "_Acme"). Blank = show logins as-is. The full login stays the identity
# key; this is cosmetic.
DISCUSSIONS_STRIP_SUFFIX=
# Public GIPHY API key. When set, the comment composer shows a client-side GIF picker
# (the browser calls GIPHY directly; rating forced to "g"). Blank = no GIF button.
DISCUSSIONS_GIPHY_KEY=

# --- Runtime (read by run.sh) ------------------------------------------------
HOST=0.0.0.0
PORT=9443
# Set both to serve HTTPS (point them at a TLS cert + key:
# certs/fullchain.pem + certs/privkey.pem). For a local non-TLS run, leave them
# unset and use HOST=127.0.0.1.
# SSL_CERTFILE=certs/fullchain.pem
# SSL_KEYFILE=certs/privkey.pem
# One log file for the whole server (uvicorn output + app logs + startup errors),
# written by run.sh under systemd. Relative to the backend dir. Default: discussions.log.
# LOG_FILE=discussions.log
