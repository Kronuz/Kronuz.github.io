---
/**
 * Full-page source viewer: /snippets/view/<file>/
 *
 * One page per file in public/snippets/, rendered inside the full Starlight
 * shell (the site menus), with a Back link (to the article you came from) and a
 * Raw link. The ```snippet fences in posts link here via their "Open" button.
 * (Route segment is [name] to avoid clashing with Astro's internal $$file.)
 */
import { readdirSync } from "node:fs";
import path from "node:path";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { readSnippet, langForFile, highlight } from "../../../lib/renderSnippet.mjs";

export function getStaticPaths() {
  const dir = path.resolve("public/snippets");
  let files = [];
  try {
    files = readdirSync(dir).filter((f) => !f.startsWith("."));
  } catch {
    files = [];
  }
  return files.map((file) => ({ params: { name: file }, props: { file } }));
}

const { file } = Astro.props;
const lang = langForFile(file);
const pre = await highlight(readSnippet(file), lang);
const raw = `/snippets/${file}`;
---

<StarlightPage frontmatter={{ title: file, tableOfContents: false }}>
  <p class="snippet-page-nav">
    <a href="/blog/" onclick="if(history.length>1){history.back();return false}">&larr; Back</a>
    <a class="snippet-btn" href={raw} target="_blank" rel="noopener">Raw &nearr;</a>
  </p>
  <figure class="snippet snippet--page" data-lang={lang}>
    <div class="snippet-code" set:html={pre}></div>
  </figure>
</StarlightPage>
