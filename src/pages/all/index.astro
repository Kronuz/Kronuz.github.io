---
/**
 * /all/ — a private, single-page index of EVERY blog post (published AND draft),
 * two lines each: date, status/featured/category badges, title + subtitle, series
 * position.
 *
 * Deliberately unlisted: not linked from any menu, excluded from the sitemap (see
 * the `sitemap({ filter })` in astro.config.mjs), kept out of Pagefind search
 * (`pagefind: false`), and marked `noindex`. A personal dashboard for reviewing the
 * whole catalog and publishing pipeline at a glance, not part of the site's
 * navigation. Sorted by date descending (newest first), so the most recent and
 * furthest-scheduled posts sit at the top.
 *
 * Every title links to its post. Draft posts aren't built in production, so a
 * draft link resolves in local dev (npm run dev, where drafts build) but 404s on
 * the deployed site, by design (that's what keeps the staggered schedule intact).
 */
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { getCollection } from "astro:content";

const CATEGORY = { announcement: "📣", tutorial: "🛠️", note: "💡" };

const bareSlug = (id) => id.replace(/\.mdx?$/, "").split("/").pop();

const all = (await getCollection("docs")).filter(
  (e) => e.id.startsWith("blog/") && e.data.date,
);

// Total parts per series, so each row can show "N/M".
const seriesTotal = {};
for (const e of all) {
  const s = e.data.series;
  if (s) seriesTotal[s] = (seriesTotal[s] ?? 0) + 1;
}

const rows = all
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .map((e) => {
    const d = e.data;
    return {
      slug: bareSlug(e.id),
      title: d.title,
      subtitle: d.subtitle ?? "",
      date: d.date ? d.date.toISOString().slice(0, 10) : "",
      draft: d.draft === true,
      featured: d.featured === true,
      category: d.category ? CATEGORY[d.category] : "",
      series: d.series ?? "",
      order: d.seriesOrder,
      total: d.series ? seriesTotal[d.series] : 0,
    };
  });

const published = rows.filter((r) => !r.draft).length;
const drafts = rows.length - published;

const head = [{ tag: "meta", attrs: { name: "robots", content: "noindex, nofollow" } }];
---

<StarlightPage frontmatter={{ title: "All Posts", tableOfContents: false, pagefind: false, head }}>
	<p class="all-summary not-content">
		{rows.length} posts · {published} published · {drafts} draft
	</p>
	<ul class="all-list not-content">
		{
			rows.map((r) => (
				<li class:list={["all-row", r.draft && "is-draft"]}>
					<time class="all-date">{r.date}</time>
					<span class="all-flags">
						{r.draft ? (
							<span class="all-pill all-pill-draft">📝 draft</span>
						) : (
							<span class="all-pill all-pill-live">live</span>
						)}
						{r.featured && <span class="all-pill all-pill-feat">⭐</span>}
						{r.category && (
							<span class="all-cat" title={r.category}>
								{r.category}
							</span>
						)}
					</span>
					<span class="all-title-block">
						<span class="all-title" title={r.title}>
							<a href={`/blog/${r.slug}/`}>{r.title}</a>
						</span>
						{r.subtitle && (
							<span class="all-subtitle" title={r.subtitle}>
								{r.subtitle}
							</span>
						)}
					</span>
					{r.series && (
						<span class="all-series">
							{r.series} {r.order}/{r.total}
						</span>
					)}
				</li>
			))
		}
	</ul>
</StarlightPage>

<style>
	.all-summary {
		color: var(--sl-color-gray-3);
		font-size: var(--sl-text-sm);
		margin: 0 0 1rem;
	}
	.all-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.all-row {
		display: flex;
		align-items: baseline;
		gap: 0.6rem;
		padding: 0.35rem 0;
		border-bottom: 1px solid var(--sl-color-gray-6);
	}
	.all-date {
		flex: 0 0 5.5rem;
		font-variant-numeric: tabular-nums;
		color: var(--sl-color-gray-3);
		font-size: var(--sl-text-sm);
	}
	.all-flags {
		flex: 0 0 7.5rem;
		display: inline-flex;
		gap: 0.3rem;
		align-items: baseline;
	}
	.all-pill {
		font-size: var(--sl-text-2xs);
		line-height: 1.6;
		border-radius: 999px;
		padding: 0.02rem 0.45rem;
		white-space: nowrap;
	}
	.all-pill-draft {
		background: var(--sl-color-orange-low);
		color: var(--sl-color-orange-high);
	}
	.all-pill-live {
		background: var(--sl-color-green-low);
		color: var(--sl-color-green-high);
	}
	.all-pill-feat {
		background: var(--sl-color-blue-low);
	}
	.all-title-block {
		flex: 1 1 auto;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.05rem;
	}
	.all-title {
		min-width: 0;
		overflow: hidden;
		white-space: nowrap;
		text-overflow: ellipsis;
	}
	.all-subtitle {
		min-width: 0;
		overflow: hidden;
		white-space: nowrap;
		text-overflow: ellipsis;
		color: var(--sl-color-gray-3);
		font-size: var(--sl-text-sm);
	}
	.is-draft .all-title a {
		color: var(--sl-color-gray-3);
	}
	.is-draft .all-subtitle {
		color: var(--sl-color-gray-4);
	}
	.all-series {
		flex: 0 0 auto;
		margin-left: auto;
		color: var(--sl-color-gray-3);
		font-size: var(--sl-text-sm);
		white-space: nowrap;
	}
</style>
