---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { listProjects } from '../../lib/projects.mjs';

const projects = await listProjects();
---

<StarlightPage
	frontmatter={{
		title: 'Projects',
		description:
			'Open-source projects by Germán Méndez Bravo (Kronuz) — search engines, developer tools, and language tooling.',
		tableOfContents: false,
	}}
>
	<p>
		Open-source projects I work (or worked) on. A fuller list lives on{' '}
		<a href="https://github.com/Kronuz?tab=repositories">my GitHub</a>.
	</p>

	<div class="projects-grid not-content">
		{
			projects.map((p) => (
				<article class="project-card">
					<p class="project-card-meta">
						{p.data.tech[0] && <span class="project-tag">{p.data.tech[0]}</span>}
						{p.data.featured && <span class="project-badge is-featured">Featured</span>}
						{p.data.status && (
							<span class={`project-badge is-${p.data.status}`}>
								{p.data.status[0].toUpperCase() + p.data.status.slice(1)}
							</span>
						)}
					</p>
					<h3 class="project-name">
						<a href={`/projects/${p.id}/`}>{p.data.title}</a>
					</h3>
					{p.data.tagline && <p class="project-tagline">{p.data.tagline}</p>}
					{p.data.description && <p class="project-desc">{p.data.description}</p>}
					<p class="project-links">
						{p.data.website && <a href={p.data.website}>Website</a>}
						{p.data.docs && <a href={p.data.docs}>Docs</a>}
						{p.data.repo && <a href={p.data.repo}>GitHub</a>}
					</p>
				</article>
			))
		}
	</div>

	<h2>Also worth a look</h2>

	<p class="projects-more not-content">
		<a href="https://github.com/Kronuz/esprima-python">esprima-python</a>
		<a href="https://github.com/Kronuz/metch">metch</a>
		<a href="https://github.com/Kronuz/stacktraces">stacktraces</a>
		<a href="https://github.com/Kronuz/base-x">base-x</a>
		<a href="https://github.com/Kronuz/uinteger_t">uinteger_t</a>
		<a href="https://github.com/Kronuz/isn">ISN for PostgreSQL</a>
		<a href="https://github.com/django/django/commits?author=Kronuz">contributions to Django</a>
	</p>
</StarlightPage>
