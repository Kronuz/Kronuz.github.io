---
// Override of starlight-blog's PrevNextLinks.astro (wired via a Vite resolveId redirect in
// astro.config.mjs). Renders the same .pagination-links > a[rel] structure as every other
// pager on the site (styled in custom.css) instead of a Starlight LinkCard, so the /blog/
// "Older/Newer posts" list pager matches the per-post and docs pagers.
//
// starlight-blog also renders this component in each post's footer; we render our own post
// pagers, so we hide that copy with `.post-footer .pagination-links { display:none }`. The
// visible list pager on /blog/ isn't inside .post-footer, so it shows.
interface Link {
	href: string;
	label?: string;
}
interface Props {
	config: { prevNextLinksOrder?: string };
	next: Link | undefined;
	prev: Link | undefined;
}

const { config, next, prev } = Astro.props;
const reverse = config?.prevNextLinksOrder !== 'chronological';
const t = Astro.locals.t;
const prevTitle = prev?.label ?? t(reverse ? 'starlightBlog.pagination.prev' : 'starlightBlog.pagination.next');
const nextTitle = next?.label ?? t(reverse ? 'starlightBlog.pagination.next' : 'starlightBlog.pagination.prev');

// starlight-blog renders this component in TWO places: the /blog/ list ("Older/Newer posts")
// and the footer of every post. On a post we render our own series + chronological pagers
// (above the comments, in MarkdownContent.astro), so we render nothing here — no footer copy
// to hide. A post's route entry has a `date`; the blog index / pagination / tag list pages
// don't, which is how we tell the two apart.
const isBlogPost = Boolean(Astro.locals.starlightRoute?.entry?.data?.date);
const show = !isBlogPost && (prev || next);

const ARROW_LEFT = '<path d="M17 11H9.41l3.3-3.29a1.004 1.004 0 1 0-1.42-1.42l-5 5a1 1 0 0 0-.21.33 1 1 0 0 0 0 .76 1 1 0 0 0 .21.33l5 5a1.002 1.002 0 0 0 1.639-.325 1 1 0 0 0-.219-1.095L9.41 13H17a1 1 0 0 0 0-2Z"/>';
const ARROW_RIGHT = '<path d="M17.92 11.62a1.001 1.001 0 0 0-.21-.33l-5-5a1.003 1.003 0 1 0-1.42 1.42l3.3 3.29H7a1 1 0 0 0 0 2h7.59l-3.3 3.29a1.002 1.002 0 0 0 .325 1.639 1 1 0 0 0 1.095-.219l5-5a1 1 0 0 0 .21-.33 1 1 0 0 0 0-.76Z"/>';
---

{
	show && (
		<nav class="pagination-links" aria-label="Blog pagination" data-pagefind-ignore>
			{prev && (
				<a href={prev.href} rel="prev">
					<svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" set:html={ARROW_LEFT} />
					<span><span class="link-title">{prevTitle}</span></span>
				</a>
			)}
			{next && (
				<a href={next.href} rel="next">
					<svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" set:html={ARROW_RIGHT} />
					<span><span class="link-title">{nextTitle}</span></span>
				</a>
			)}
		</nav>
	)
}
