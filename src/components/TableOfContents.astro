---
// Overrides Starlight's right-sidebar "On this page". Renders the default table of
// contents, then, on posts that belong to an article series (frontmatter `series`),
// appends a compact stepper below it. Desktop-only (the right sidebar is hidden on
// mobile, where MarkdownContent's one-liner + prev/next pager carry the series instead).
// Project pages (a separate collection, rendered via StarlightPage) can't be resolved
// here without importing the projects collection, which the internal mirror lacks — so
// the project route resolves its own series and passes it in via `Astro.locals.projectSeries`.
import Default from '@astrojs/starlight/components/TableOfContents.astro';
import { resolveSeries } from '../lib/series.mjs';
import { tocHasHeadings } from '../lib/toc.mjs';

const { entry, toc } = Astro.locals.starlightRoute;
const isBlogPost = Boolean(entry?.data?.date);
const term = (entry?.id ?? '').replace(/\.mdx?$/, '');
const series = Astro.locals.projectSeries ?? (isBlogPost ? await resolveSeries(term) : null);
const showSeries = Boolean(toc) && Boolean(series?.inSeries);
// The column survives heading-less pages only to carry the stepper (see the route
// middleware); on those, suppress the bare "Overview"-only list so just the stepper shows.
const showToc = tocHasHeadings(toc);
---

{
	showSeries && (
		<nav class="series-aside" aria-label="Series navigation">
			<h2 class="series-aside-title">{series.name}</h2>
			<p class="series-aside-sub">Part {series.index + 1} of {series.total}</p>
			{series.chapters && (
				<Fragment>
					<input type="checkbox" id="series-group-aside" class="series-group-input" checked />
					<label for="series-group-aside" class="series-group-toggle" title="Group by chapter">
						<span class="series-group-track"><span class="series-group-thumb" /></span>
						<span class="series-group-text">Group</span>
					</label>
					<div class="series-grouped">
						{series.chapters.map((ch) => (
							<details class="series-chapter" open={ch.hasCurrent}>
								<summary class:list={["series-chapter-head", ch.hasCurrent && "is-here"]}>
									<span class="series-chapter-name">{ch.title}</span>
									<span class="series-chapter-count">{ch.parts.length}</span>
								</summary>
								<ol class="series-aside-list">
									{ch.parts.map((p) => (
										<li>
											{p.current ? (
												<span class="series-aside-row is-current">
													<span class="series-aside-num">{p.index + 1}</span>
													<span class="series-aside-text">{p.title}</span>
												</span>
											) : p.reachable ? (
												<a class:list={["series-aside-row", p.pending && "is-pending"]} href={`${series.base}/${p.slug}/`}>
													<span class="series-aside-num">{p.index + 1}</span>
													<span class="series-aside-text">{p.title}</span>
												</a>
											) : (
												<span class="series-aside-row is-pending">
													<span class="series-aside-num">{p.index + 1}</span>
													<span class="series-aside-text">{p.title}</span>
												</span>
											)}
										</li>
									))}
								</ol>
							</details>
						))}
					</div>
				</Fragment>
			)}
			<ol class:list={["series-aside-list", series.chapters && "series-flat"]}>
				{series.parts.map((p) => (
					<li>
						{p.current ? (
							<span class="series-aside-row is-current">
								<span class="series-aside-num">{p.index + 1}</span>
								<span class="series-aside-text">{p.title}</span>
							</span>
						) : p.reachable ? (
							<a class:list={["series-aside-row", p.pending && "is-pending"]} href={`${series.base}/${p.slug}/`}>
								<span class="series-aside-num">{p.index + 1}</span>
								<span class="series-aside-text">{p.title}</span>
							</a>
						) : (
							<span class="series-aside-row is-pending">
								<span class="series-aside-num">{p.index + 1}</span>
								<span class="series-aside-text">{p.title}</span>
							</span>
						)}
					</li>
				))}
			</ol>
		</nav>
	)
}

{showToc && <Default />}

<style>
	.series-aside {
		margin-bottom: 1.5rem;
		padding-bottom: 1.25rem;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
	.series-aside-title {
		margin: 0;
		font-size: var(--sl-text-h5);
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-white);
	}
	.series-aside-sub {
		margin: 0.2rem 0 0.6rem;
		font-size: var(--sl-text-xs);
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--sl-color-text-accent);
	}
	.series-aside-list {
		position: relative;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	/* The continuous rail threading the numbered nodes. */
	.series-aside-list::before {
		content: '';
		position: absolute;
		/* Center the 2px rail on the number circles: row padding-left (0.3rem) +
		   half the 1.4rem circle (0.7rem) = 1rem, minus half the rail width. */
		left: calc(1rem - 1px);
		top: 0.9rem;
		bottom: 0.9rem;
		width: 2px;
		background: var(--sl-color-gray-5);
	}
	.series-aside-list li {
		margin: 0;
	}
	.series-aside-row {
		display: flex;
		align-items: flex-start;
		gap: 0.5rem;
		padding: 0.25rem 0.3rem;
		border-radius: 0.4rem;
		text-decoration: none;
		color: var(--sl-color-gray-2);
		line-height: 1.3;
	}
	a.series-aside-row:hover {
		background: var(--sl-color-gray-6);
	}
	.series-aside-num {
		position: relative;
		z-index: 1;
		flex: 0 0 auto;
		width: 1.4rem;
		height: 1.4rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		border: 1px solid var(--sl-color-gray-4);
		background: var(--sl-color-bg-sidebar, var(--sl-color-gray-6));
		font-size: var(--sl-text-2xs);
		font-weight: 600;
		color: var(--sl-color-gray-2);
	}
	.series-aside-text {
		font-size: var(--sl-text-xs);
		padding-top: 0.08rem;
	}
	a.series-aside-row .series-aside-text {
		color: var(--sl-color-text-accent);
	}
	a.series-aside-row:hover .series-aside-text {
		text-decoration: underline;
	}
	.series-aside-row.is-current {
		background: color-mix(in srgb, var(--sl-color-text-accent) 12%, transparent);
	}
	.series-aside-row.is-current .series-aside-num {
		background: var(--sl-color-text-accent);
		border-color: var(--sl-color-text-accent);
		color: var(--sl-color-black);
	}
	.series-aside-row.is-current .series-aside-text {
		color: var(--sl-color-white);
		font-weight: 600;
	}
	.series-aside-row.is-pending {
		color: var(--sl-color-gray-4);
	}
	.series-aside-row.is-pending .series-aside-num {
		color: var(--sl-color-gray-4);
		border-style: dashed;
	}
	/* In `npm run dev` a pending part is reachable, so it renders as a greyed link
	   (clickable to preview, still visibly pending). Hold the muted color over the accent
	   link color above; the hover underline stays as the link affordance. */
	a.series-aside-row.is-pending .series-aside-text {
		color: var(--sl-color-gray-4);
	}

	/* --- Chapter grouping (collapsible book-TOC for long series) --- */
	.series-chapter {
		margin: 0;
	}
	.series-chapter + .series-chapter {
		margin-top: 0.1rem;
	}
	/* The chapter header (a <summary>): our own disclosure triangle, no native marker. */
	.series-chapter-head {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.3rem 0.35rem;
		border-radius: 0.4rem;
		cursor: pointer;
		list-style: none;
		color: var(--sl-color-white);
		font-size: var(--sl-text-xs);
		font-weight: 600;
	}
	.series-chapter-head::-webkit-details-marker {
		display: none;
	}
	.series-chapter-head::before {
		content: '';
		flex: 0 0 auto;
		width: 0;
		height: 0;
		border-left: 4px solid currentColor;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
		opacity: 0.55;
		transition: transform 0.15s ease;
	}
	.series-chapter[open] > .series-chapter-head::before {
		transform: rotate(90deg);
	}
	.series-chapter-head:hover {
		background: var(--sl-color-gray-6);
	}
	/* A collapsed chapter that holds the current part still reads as "you are here". */
	.series-chapter-head.is-here .series-chapter-name {
		color: var(--sl-color-text-accent);
	}
	.series-chapter-name {
		flex: 1 1 auto;
	}
	.series-chapter-count {
		flex: 0 0 auto;
		font-size: var(--sl-text-2xs);
		font-weight: 600;
		color: var(--sl-color-gray-3);
		background: var(--sl-color-gray-6);
		border-radius: 999px;
		padding: 0.02rem 0.4rem;
	}
	/* Indent the parts under a chapter and shift the rail to match the deeper circles. */
	.series-chapter .series-aside-list {
		padding-left: 0.9rem;
		margin-bottom: 0.15rem;
	}
	.series-chapter .series-aside-list::before {
		left: calc(1.9rem - 1px);
	}

	/* --- "Group" toggle: flip the stepper between chapters and flat read order --- */
	/* Pure CSS: a visually-hidden but focusable checkbox drives the two views. Default
	   checked = grouped; unchecked = flat read order (1..N). No JS, so it resets per page. */
	.series-group-input {
		position: absolute;
		width: 1px;
		height: 1px;
		opacity: 0;
		margin: 0;
	}
	.series-grouped {
		display: none;
	}
	.series-group-input:checked ~ .series-grouped {
		display: block;
	}
	.series-group-input:checked ~ .series-flat {
		display: none;
	}
	.series-group-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin: 0 0 0.6rem;
		cursor: pointer;
		user-select: none;
		font-size: var(--sl-text-2xs);
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--sl-color-gray-3);
	}
	.series-group-track {
		position: relative;
		flex: 0 0 auto;
		width: 1.7rem;
		height: 1rem;
		border-radius: 1rem;
		background: var(--sl-color-gray-5);
		transition: background 0.15s ease;
	}
	.series-group-thumb {
		position: absolute;
		top: 0.13rem;
		left: 0.13rem;
		width: 0.74rem;
		height: 0.74rem;
		border-radius: 50%;
		background: var(--sl-color-white);
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
		transition: transform 0.15s ease;
	}
	.series-group-input:checked ~ .series-group-toggle .series-group-track {
		background: var(--sl-color-accent);
	}
	.series-group-input:checked ~ .series-group-toggle .series-group-thumb {
		transform: translateX(0.7rem);
	}
	.series-group-input:focus-visible ~ .series-group-toggle .series-group-track {
		outline: 2px solid var(--sl-color-text-accent);
		outline-offset: 2px;
	}
</style>
