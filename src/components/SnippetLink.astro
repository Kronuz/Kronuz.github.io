---
/**
 * <SnippetLink file="statusline.sh">label</SnippetLink>
 *   default        clicking opens a centered modal (native <dialog>) with the
 *                  highlighted code plus Open / Raw / Copy / Close.
 *   page (boolean) clicking goes straight to the full-page viewer
 *                  (/snippets/view/<file>/) instead — a plain inline link.
 *
 * The dialog markup lives in an inert <template> (valid inline, renders nothing,
 * so it doesn't break the surrounding paragraph) and is cloned to <body> on
 * click — that keeps the link truly inline and lets showModal() center it. With
 * JS off, the modal link falls back to the raw file. Click handling (open / copy
 * / close) is shared with the full-page view via <SnippetScript>.
 */
import { readSnippet, langForFile, highlight, rawHref } from "../lib/renderSnippet.mjs";
import SnippetScript from "./SnippetScript.astro";

const { file, page } = Astro.props;
const lang = langForFile(file);
const raw = rawHref(file);
const viewHref = `/snippets/view/${file}/`;
const id = `snip-${file.replace(/[^a-z0-9]+/gi, "-")}-${Math.random().toString(36).slice(2, 8)}`;
const pre = page ? "" : await highlight(readSnippet(file), lang);
---

<a class:list={["snippet-link", page && "snippet-link--page"]} href={page ? viewHref : raw} data-snippet-open={page ? undefined : id}><slot>{file}</slot></a>{page ? null : (<template data-snippet-tpl={id}><dialog class="snippet-dialog" aria-label={`Source: ${file}`}><figure class="snippet snippet--modal" data-lang={lang}><figcaption class="snippet-bar"><span class="snippet-title">{file}</span><span class="snippet-actions"><a class="snippet-btn" href={viewHref}>Open</a><a class="snippet-btn" href={raw} target="_blank" rel="noopener">Raw</a><a class="snippet-btn snippet-icon-btn snippet-download" href={raw} download={file} aria-label={`Download ${file}`} title={`Download ${file}`}><svg class="snippet-i snippet-i-download" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><path d="M7 10l5 5 5-5"></path><path d="M12 15V3"></path></svg></a><button class="snippet-btn snippet-icon-btn snippet-copy" type="button" data-snippet-copy aria-label="Copy to clipboard" title="Copy to clipboard"><svg class="snippet-i snippet-i-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg></button><button class="snippet-btn snippet-icon-btn snippet-close" type="button" data-snippet-close aria-label="Close" title="Close"><svg class="snippet-i" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"></path></svg></button></span></figcaption><div class="snippet-code" set:html={pre} /></figure></dialog></template>)}<SnippetScript />
