---
// Animates the landing hero's REPL: kronuz.whoami() "answers" by typing out a
// rotating line that ends on the warm Kronuz caret (#kz-answer lives in the
// splash <h1>, set via hero.title). Reduced-motion users keep the static answer.
// Also exposes a real, callable `kronuz` on window, so anyone who opens the
// console can actually run kronuz.whoami() (see the easter egg below).
---

<script>
	const el = document.getElementById('kz-answer');
	// Kept short on purpose: these type out in the hero and must fit a phone screen.
	const answers = [
		"'C and C++, Python by chance'",
		"'reads what the code hides'",
		"'a reverse engineer at heart'",
		"'the SoftICE kid, grown up'",
		"'redraws only what changed'",
		"'benchmarks over opinions'",
		"'proof, not adjectives'",
		"'files it until it is elegant'",
		"'always one more benchmark'",
		"'a perfect hash, no collisions'",
		"'pays for less than it imports'",
		"'Germán offline, Kronuz online'",
		"'co-author of PEP 810'",
		"'makes Python explain itself'",
		"'the reason imports got lazy'",
		"'named the frozen loop'",
		"'runtime patches, no redeploy'",
		"'convinced the GIL is optional'",
		"'immortal objects, no churn'",
		"'keeps the GC off the hot path'",
		"'seconds off start-up'",
		"'wins in dollars and watts'",
		"'happiest a layer below'",
		"'here for the stack traces'",
		"'allergic to blocking in async'",
	];

	// A real, callable kronuz for whoever opens the console. whoami() returns a
	// fresh answer (minus the display quotes, so the console prints it cleanly).
	const kronuz = {
		whoami() { return answers[Math.floor(Math.random() * answers.length)].replace(/^'|'$/g, ''); },
		help()   { return 'try kronuz.whoami(), then read the source. that is more my style anyway.'; },
		toString() { return '<kronuz: reverse engineer at heart>'; },
	};
	// @ts-ignore , intentional global for the console easter egg.
	window.kronuz = kronuz;

	// For the curious who open the console. If you are reading this, you are exactly my
	// kind of person: the ones who look under the hood. Go on, call it.
	console.log(
		"%c>>> kronuz.whoami()\n%cyou opened the console, so you are my kind of person. go on, call it:  kronuz.whoami()\n(then read the source, and push it further than it should go. roll for initiative.)",
		"color:#7fbf7f;font-weight:bold;font-family:monospace",
		"color:#7fbf7f;font-family:monospace"
	);

	const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	if (el && !reduce) {
		const sleep = (ms) => new Promise((r) => setTimeout(r, ms));
		let i = Math.floor(Math.random() * answers.length);
		el.textContent = '';
		(async () => {
			await sleep(400);
			while (true) {
				const next = answers[i];
				for (let n = 1; n <= next.length; n++) {
					el.textContent = next.slice(0, n);
					await sleep(42);
				}
				await sleep(2500);
				const cur = el.textContent ?? '';
				for (let n = cur.length; n >= 0; n--) {
					el.textContent = cur.slice(0, n);
					await sleep(26);
				}
				let j;
				do { j = Math.floor(Math.random() * answers.length); } while (j === i && answers.length > 1);
				i = j;
			}
		})();
	}
</script>
