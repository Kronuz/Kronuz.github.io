---
import EditLink from 'virtual:starlight/components/EditLink';
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
import { Icon } from '@astrojs/starlight/components';

// One <footer> for the whole site. We inline Starlight's default footer parts
// (edit link, last-updated, prev/next pagination) instead of wrapping the
// stock Footer, because that component exposes no slot — so the site footer
// (copyright + social) can live *inside* the same <footer>, which is both more
// semantic and means there's no separate empty footer pushing it down.
// Same links as the header social bar, plus Email.
const social = [
	{ icon: 'github', label: 'GitHub', href: 'https://github.com/Kronuz' },
	{ icon: 'linkedin', label: 'LinkedIn', href: 'https://www.linkedin.com/in/kronuz/' },
	{ icon: 'x.com', label: 'X', href: 'https://twitter.com/germbravo' },
	{ icon: 'stackOverflow', label: 'Stack Overflow', href: 'https://stackoverflow.com/users/167522/kronuz' },
	{ icon: 'email', label: 'Email', href: 'mailto:german.mb@gmail.com' },
];

const year = new Date().getFullYear();
---

<footer class="sl-flex kz-footer">
	<div class="meta sl-flex">
		<EditLink />
		<LastUpdated />
	</div>
	<Pagination />

	<div class="kz-site-footer">
		<p class="kz-copyright">&copy; {year} Germán Méndez Bravo</p>
		<div class="kz-social">
			{
				social.map((s) => (
					<a
						href={s.href}
						class="kz-social-link"
						aria-label={s.label}
						title={s.label}
						rel="noopener noreferrer"
						target={s.href.startsWith('http') ? '_blank' : undefined}
					>
						<Icon name={s.icon as any} />
					</a>
				))
			}
			<a
				href="https://www.paypal.me/Kronuz"
				class="kz-social-link"
				aria-label="PayPal.me"
				title="PayPal.me"
				rel="noopener noreferrer"
				target="_blank"
			>
				<svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M7.016 19.198h-4.2a.562.562 0 0 1-.555-.65L5.093.584A.692.692 0 0 1 5.776 0h7.222c3.417 0 5.904 2.488 5.846 5.5-.006.25-.027.5-.066.747A6.794 6.794 0 0 1 12.071 12H8.743a.69.69 0 0 0-.682.583l-.325 2.056-.013.083-.692 4.39-.015.087zM19.79 6.142c-.01.087-.01.175-.023.261a7.76 7.76 0 0 1-7.695 6.598H9.007l-.283 1.795-.013.083-.692 4.39-.134.843-.014.088H6.86l-.497 3.15a.562.562 0 0 0 .555.65h3.612c.34 0 .63-.249.683-.585l.952-6.031a.692.692 0 0 1 .683-.584h2.126a6.793 6.793 0 0 0 6.707-5.752c.306-1.95-.466-3.744-1.89-4.906z" /></svg>
			</a>
		</div>
	</div>
</footer>
