---
import Default from '@astrojs/starlight/components/ThemeSelect.astro';

// Header site menu: Blog + Projects, shown before the theme selector (desktop
// only — mobile uses the hamburger sidebar). This replaces starlight-blog's
// built-in single "Blog" injector (we set its `navigation: 'none'`), so we own
// the links. Styling mirrors starlight-blog's nav (accent links, separator).
---

<nav class="kz-topnav" aria-label="Site">
	<a href="/blog/">Blog</a>
	<a href="/projects/">Projects</a>
</nav>
<Default><slot /></Default>

<style>
	.kz-topnav {
		border-inline-end: 1px solid var(--sl-color-gray-5);
		display: none;
		gap: 1rem;
		padding-inline-end: 1rem;
		align-items: center;
	}
	@media (min-width: 50rem) {
		.kz-topnav {
			display: flex;
		}
	}
	.kz-topnav a {
		color: var(--sl-color-text-accent);
		font-weight: 600;
		text-decoration: none;
	}
	.kz-topnav a:hover {
		text-decoration: underline;
	}
</style>
