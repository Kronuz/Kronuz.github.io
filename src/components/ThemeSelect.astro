---
import Default from '@astrojs/starlight/components/ThemeSelect.astro';
import { Icon } from '@astrojs/starlight/components';

// Header site menu, shown before the theme selector. Replaces starlight-blog's
// built-in single "Blog" injector (we set its `navigation: 'none'`), so we own
// the links. Visible on every screen size: icon + text on desktop, icon-only on
// mobile (so the menu stays reachable even on the splash, which has no sidebar
// hamburger). aria-label keeps the labels for screen readers when text hides.
const items = [
{ label: 'About', href: '/about/', icon: 'information' },
{ label: 'Blog', href: '/blog/', icon: 'open-book' },
{ label: 'RSS', href: '/blog/rss.xml', icon: 'rss', external: true },
];
---

<nav class="kz-topnav" aria-label="Site">
{
items.map((it) => (
<a
href={it.href}
class="kz-topnav-link"
aria-label={it.label}
title={it.label}
target={it.external ? '_blank' : undefined}
rel={it.external ? 'noopener' : undefined}
>
<Icon name={it.icon as any} size="1.25rem" />
<span class="kz-topnav-label">{it.label}</span>
</a>
))
}
</nav>
<Default><slot /></Default>

<style>
.kz-topnav {
display: flex;
align-items: center;
gap: 0.6rem;
padding-inline-end: 0.85rem;
border-inline-end: 1px solid var(--sl-color-gray-5);
}
.kz-topnav-link {
display: inline-flex;
align-items: center;
gap: 0.3rem;
color: var(--sl-color-text-accent);
font-weight: 600;
text-decoration: none;
}
.kz-topnav-link svg {
display: block;
flex-shrink: 0;
}
.kz-topnav-link:hover {
text-decoration: underline;
}
/* Icons only at every size; the sidebar carries the labeled About / Blog / RSS,
   so the header stays compact. Labels remain in aria-label + title (tooltip). */
.kz-topnav-label {
display: none;
}
@media (min-width: 50rem) {
.kz-topnav {
gap: 1rem;
padding-inline-end: 1rem;
}
}
</style>
