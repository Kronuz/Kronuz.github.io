---
// Wraps starlight-blog's MarkdownContent override (which renders the blog post frame:
// metadata, body, tags, prev/next) and, on individual blog posts only, adds the
// article-series UI (the sidebar stepper lives in the TableOfContents override; here:
// a mobile-only series chip, the prev/next pagers, and an end-of-article divider) plus
// discussions. Gated on `entry.data.date` (blog posts have it; the splash and
// About/Projects pages don't), so none of it appears on non-blog pages.
//
// Setting `components.MarkdownContent` makes starlight-blog log a one-line build WARN
// ("you already have a MarkdownContent override") and skip its own registration.
// That's expected: we re-import its override below, so the blog frame still renders.
import BlogMarkdownContent from 'starlight-blog/overrides/MarkdownContent.astro';
import Discussions from '../../discussions/astro/Discussions.astro';
import SnippetScript from './SnippetScript.astro';
import { resolveSeries, resolveChronological } from '../lib/series.mjs';
import { DISCUSSIONS_ACCESS_KEY, DISCUSSIONS_BACKEND, DISCUSSIONS_STRIP_SUFFIX, DISCUSSIONS_GIPHY_KEY } from '../consts';

const { entry } = Astro.locals.starlightRoute;
const isBlogPost = Boolean(entry?.data?.date);
const term = (entry?.id ?? '').replace(/\.mdx?$/, '');
// starlight-blog's MarkdownContent override treats every /blog/* path as a post (its
// isAnyBlogPostPage in libs/page.ts) and calls getBlogEntry(), which throws for a non-post
// page we add under /blog/ (e.g. the /blog/all/ dashboard). List those reserved subpaths
// here so we render them as a plain page instead of delegating to the blog post frame.
const RESERVED_BLOG = new Set(['blog/all']);
const isReservedBlogPage = RESERVED_BLOG.has(term);

// The full series stepper lives in the right sidebar (the TableOfContents override).
// Here we keep only the in-content pieces: a mobile-only one-liner (the sidebar is
// hidden on small screens) and the prev/next pagers.
const series = isBlogPost ? await resolveSeries(term) : null;
const inSeries = Boolean(series?.inSeries);
const seriesPrev = series?.prev ?? null;
const seriesNext = series?.next ?? null;
// Render the chronological blog pager ourselves, below the article and next to the
// series pager, instead of where starlight-blog puts it (the footer, below comments).
// We hide that native one in CSS (.post-footer .pagination).
const chrono = isBlogPost ? await resolveChronological(term) : null;
const chronoPrev = chrono?.prev ?? null;
const chronoNext = chrono?.next ?? null;
// Comments use the tenant base URL from consts or the local-development override.
const title = entry?.data?.title;
const subtitle = entry?.data?.subtitle;
const url = Astro.url?.href;
const backend = import.meta.env.PUBLIC_DISCUSSIONS_BACKEND || DISCUSSIONS_BACKEND;
const accessKey = import.meta.env.PUBLIC_DISCUSSIONS_ACCESS_KEY || DISCUSSIONS_ACCESS_KEY;
const inlineComments = Boolean(backend) && isBlogPost && Boolean(term);
// Prev/next arrows for the hand-rolled pagers (same glyphs as Starlight's Icon left/right-
// arrow), so these pagers render the exact .pagination-links > a structure the native docs
// pager uses — each <a> is the whole button. See .pagination-links in custom.css.
const ARROW_LEFT = '<path d="M17 11H9.41l3.3-3.29a1.004 1.004 0 1 0-1.42-1.42l-5 5a1 1 0 0 0-.21.33 1 1 0 0 0 0 .76 1 1 0 0 0 .21.33l5 5a1.002 1.002 0 0 0 1.639-.325 1 1 0 0 0-.219-1.095L9.41 13H17a1 1 0 0 0 0-2Z"/>';
const ARROW_RIGHT = '<path d="M17.92 11.62a1.001 1.001 0 0 0-.21-.33l-5-5a1.003 1.003 0 1 0-1.42 1.42l3.3 3.29H7a1 1 0 0 0 0 2h7.59l-3.3 3.29a1.002 1.002 0 0 0 .325 1.639 1 1 0 0 0 1.095-.219l5-5a1 1 0 0 0 .21-.33 1 1 0 0 0 0-.76Z"/>';
---

{isReservedBlogPage ? <slot /> : <BlogMarkdownContent>
	{
		inSeries && (
			<details class="series-mobile not-content">
				<summary class="series-mobile-summary">
					<span class="series-mobile-num">Part {series.index + 1} of {series.total}</span>
					<span class="series-mobile-of">of</span>
					<span class="series-mobile-name">{series.name}</span>
				</summary>
				{series.chapters && (
					<Fragment>
						<input type="checkbox" id="series-group-mobile" class="series-group-input" checked />
						<label for="series-group-mobile" class="series-group-toggle" title="Group by chapter">
							<span class="series-group-track"><span class="series-group-thumb" /></span>
							<span class="series-group-text">Group</span>
						</label>
						<div class="series-grouped">
							{series.chapters.map((ch) => (
								<div class="series-mobile-chapter">
									<p class="series-mobile-chaptername">
										<span>{ch.title}</span>
										<span class="series-mobile-chaptercount">{ch.parts.length}</span>
									</p>
									<ol class="series-mobile-list">
										{ch.parts.map((p) => (
											<li>
												{p.current ? (
													<span class="series-mobile-row is-current">
														<span class="series-mobile-rownum">{p.index + 1}</span>
														<span>{p.title}</span>
													</span>
												) : p.reachable ? (
													<a class:list={["series-mobile-row", p.pending && "is-pending"]} href={`${series.base}/${p.slug}/`}>
														<span class="series-mobile-rownum">{p.index + 1}</span>
														<span>{p.title}</span>
													</a>
												) : (
													<span class="series-mobile-row is-pending">
														<span class="series-mobile-rownum">{p.index + 1}</span>
														<span>{p.title}</span>
													</span>
												)}
											</li>
										))}
									</ol>
								</div>
							))}
						</div>
					</Fragment>
				)}
				<ol class:list={["series-mobile-list", series.chapters && "series-flat"]}>
					{series.parts.map((p) => (
						<li>
							{p.current ? (
								<span class="series-mobile-row is-current">
									<span class="series-mobile-rownum">{p.index + 1}</span>
									<span>{p.title}</span>
								</span>
							) : p.reachable ? (
								<a class:list={["series-mobile-row", p.pending && "is-pending"]} href={`${series.base}/${p.slug}/`}>
									<span class="series-mobile-rownum">{p.index + 1}</span>
									<span>{p.title}</span>
								</a>
							) : (
								<span class="series-mobile-row is-pending">
									<span class="series-mobile-rownum">{p.index + 1}</span>
									<span>{p.title}</span>
								</span>
							)}
						</li>
					))}
				</ol>
			</details>
		)
	}
	<slot />
	{
		(seriesPrev || seriesNext) && (
			<div class="post-pagers post-pagers-series">
				<nav class="pagination-links series-pager" aria-label="Series navigation" data-pagefind-ignore>
					{seriesPrev && (
						<a href={`/blog/${seriesPrev.slug}/`} rel="prev" class:list={{ "is-pending": seriesPrev.pending }}>
							<svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" set:html={ARROW_LEFT} />
							<span>Previous in series<br /><span class="link-title">{seriesPrev.title}</span></span>
						</a>
					)}
					{seriesNext && (
						<a href={`/blog/${seriesNext.slug}/`} rel="next" class:list={{ "is-pending": seriesNext.pending }}>
							<svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" set:html={ARROW_RIGHT} />
							<span>Next in series<br /><span class="link-title">{seriesNext.title}</span></span>
						</a>
					)}
				</nav>
			</div>
		)
	}
	{isBlogPost && <div class="post-divider" role="presentation" />}
	{isBlogPost && inlineComments && <Discussions term={term} title={title} subtitle={subtitle} url={url} backend={backend} accessKey={accessKey} stripSuffix={DISCUSSIONS_STRIP_SUFFIX} giphyKey={DISCUSSIONS_GIPHY_KEY} />}
	{
		(chronoPrev || chronoNext) && (
			<div class="post-pagers post-pagers-chrono">
				<nav class="pagination-links" aria-label="Blog navigation" data-pagefind-ignore>
					{chronoPrev && (
						<a href={`/blog/${chronoPrev.slug}/`} rel="prev">
							<svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" set:html={ARROW_LEFT} />
							<span>Newer<br /><span class="link-title">{chronoPrev.title}</span></span>
						</a>
					)}
					{chronoNext && (
						<a href={`/blog/${chronoNext.slug}/`} rel="next">
							<svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" set:html={ARROW_RIGHT} />
							<span>Older<br /><span class="link-title">{chronoNext.title}</span></span>
						</a>
					)}
				</nav>
			</div>
		)
	}
	{isBlogPost && <SnippetScript />}
</BlogMarkdownContent>}

<style>
	/* Mobile-only series nav. The full stepper lives in the right sidebar (the
	   TableOfContents override), which Starlight hides below 72rem, so on small screens
	   show a compact chip that expands to the full clickable part list (so mobile readers
	   can see and jump within the series, not just step prev/next). */
	.series-mobile {
		margin: 1.5rem 0 0;
	}
	.series-mobile-summary {
		display: inline-flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.35rem;
		padding: 0.35rem 0.75rem;
		border: 1px solid var(--sl-color-gray-5);
		border-left: 3px solid var(--sl-color-text-accent);
		border-radius: 1.2rem;
		background: var(--sl-color-gray-6);
		line-height: 1.4;
		cursor: pointer;
		list-style: none;
	}
	.series-mobile-summary::-webkit-details-marker {
		display: none;
	}
	.series-mobile-summary::after {
		content: '▸';
		margin-inline-start: 0.15rem;
		color: var(--sl-color-text-accent);
		font-size: var(--sl-text-xs);
		transition: transform 0.15s ease;
	}
	.series-mobile[open] .series-mobile-summary::after {
		transform: rotate(90deg);
	}
	.series-mobile-num {
		font-size: var(--sl-text-2xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		white-space: nowrap;
		color: var(--sl-color-text-accent);
	}
	.series-mobile-of {
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
	}
	.series-mobile-name {
		font-size: var(--sl-text-xs);
		font-weight: 600;
		color: var(--sl-color-white);
	}
	.series-mobile-list {
		list-style: none;
		margin: 0.75rem 0 0;
		padding: 0 0 0 0.35rem;
	}
	/* Chapter grouping inside the mobile chip (mirrors the desktop stepper). */
	.series-mobile-chapter + .series-mobile-chapter {
		margin-top: 0.4rem;
	}
	.series-mobile-chaptername {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		margin: 0.6rem 0 0.1rem;
		font-size: var(--sl-text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		color: var(--sl-color-white);
	}
	.series-mobile-chaptercount {
		font-size: var(--sl-text-2xs);
		font-weight: 600;
		color: var(--sl-color-gray-3);
		background: var(--sl-color-gray-6);
		border-radius: 999px;
		padding: 0.02rem 0.4rem;
	}
	.series-mobile-chapter .series-mobile-list {
		margin-top: 0.1rem;
	}
	/* "Group" toggle: flip the mobile list between chapters and flat read order.
	   Pure CSS (default grouped; resets per page). Same control as the desktop stepper. */
	.series-group-input {
		position: absolute;
		width: 1px;
		height: 1px;
		opacity: 0;
		margin: 0;
	}
	.series-grouped {
		display: none;
	}
	.series-group-input:checked ~ .series-grouped {
		display: block;
	}
	.series-group-input:checked ~ .series-flat {
		display: none;
	}
	.series-group-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin: 0.75rem 0 0;
		cursor: pointer;
		user-select: none;
		font-size: var(--sl-text-2xs);
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--sl-color-gray-3);
	}
	.series-group-track {
		position: relative;
		flex: 0 0 auto;
		width: 1.7rem;
		height: 1rem;
		border-radius: 1rem;
		background: var(--sl-color-gray-5);
		transition: background 0.15s ease;
	}
	.series-group-thumb {
		position: absolute;
		top: 0.13rem;
		left: 0.13rem;
		width: 0.74rem;
		height: 0.74rem;
		border-radius: 50%;
		background: var(--sl-color-white);
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
		transition: transform 0.15s ease;
	}
	.series-group-input:checked ~ .series-group-toggle .series-group-track {
		background: var(--sl-color-accent);
	}
	.series-group-input:checked ~ .series-group-toggle .series-group-thumb {
		transform: translateX(0.7rem);
	}
	.series-group-input:focus-visible ~ .series-group-toggle .series-group-track {
		outline: 2px solid var(--sl-color-text-accent);
		outline-offset: 2px;
	}
	.series-mobile-list li {
		margin: 0;
	}
	.series-mobile-row {
		display: flex;
		align-items: flex-start;
		gap: 0.5rem;
		padding: 0.3rem 0.4rem;
		border-radius: 0.4rem;
		text-decoration: none;
		color: var(--sl-color-gray-2);
		font-size: var(--sl-text-sm);
		line-height: 1.3;
	}
	a.series-mobile-row {
		color: var(--sl-color-text-accent);
	}
	a.series-mobile-row:hover {
		background: var(--sl-color-gray-6);
	}
	.series-mobile-rownum {
		flex: 0 0 auto;
		width: 1.4rem;
		height: 1.4rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		border: 1px solid var(--sl-color-gray-4);
		font-size: var(--sl-text-2xs);
		font-weight: 600;
		color: var(--sl-color-gray-2);
	}
	.series-mobile-row.is-current {
		background: color-mix(in srgb, var(--sl-color-text-accent) 12%, transparent);
		color: var(--sl-color-white);
		font-weight: 600;
	}
	.series-mobile-row.is-current .series-mobile-rownum {
		background: var(--sl-color-text-accent);
		border-color: var(--sl-color-text-accent);
		color: var(--sl-color-black);
	}
	.series-mobile-row.is-pending {
		color: var(--sl-color-gray-4);
	}
	.series-mobile-row.is-pending .series-mobile-rownum {
		color: var(--sl-color-gray-4);
		border-style: dashed;
	}
	@media (min-width: 72rem) {
		.series-mobile {
			display: none;
		}
	}

	/* Two prev/next pagers, each a native-style .pagination-links (hand-rolled <a> buttons
	   matching Starlight's docs pager; styled in custom.css). The series pager sits right
	   where the article ends; the chronological pager sits at the very bottom, above the
	   tags/footer, with a divider above it separating it from the comments.
	   (starlight-blog's own chronological pager is hidden in custom.css.) */
	.post-pagers {
		margin-top: 2.5rem;
	}
	/* A hairline that always marks the end of the article, whether or not a series
	   pager is present (it tightens up against the series pager when there is one). */
	.post-divider {
		height: 0;
		border: 0;
		border-top: 1px solid var(--sl-color-gray-5);
		margin-top: 2.5rem;
	}
	.post-pagers-series + .post-divider {
		margin-top: 1.5rem;
	}
	.post-pagers-chrono {
		padding-top: 1.5rem;
		border-top: 1px solid var(--sl-color-gray-5);
	}
</style>
